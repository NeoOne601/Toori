<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.toori.app</string>
    <key>CFBundleName</key>
    <string>Toori Lens</string>
    <key>NSCameraUsageDescription</key>
    <string>Toori uses the camera to build a searchable memory of what the lens sees.</string>
