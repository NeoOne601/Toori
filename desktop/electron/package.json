{
  "name": "toori-electron",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "npm run build && VITE_DEV_SERVER_URL='' node node_modules/electron/cli.js .",
    "electron:dev": "VITE_DEV_SERVER_URL=http://localhost:5173 node node_modules/electron/cli.js .",
    "start:bundle": "node scripts/start-dev-app.cjs",
    "web": "vite --host 127.0.0.1 --port 4173",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@types/react-grid-layout": "^1.3.6",
    "@types/react-resizable": "^3.0.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^2.2.3",
    "react-resizable": "^3.1.3",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^26.2.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
