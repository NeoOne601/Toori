{
  "name": "toori-electron",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "npm run build && VITE_DEV_SERVER_URL='' node node_modules/electron/cli.js .",
    "electron:dev": "VITE_DEV_SERVER_URL=http://localhost:5173 node node_modules/electron/cli.js .",
    "start:bundle": "node scripts/start-dev-app.cjs",
    "web": "vite --host 127.0.0.1 --port 4173",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cytoscape": "^3.30.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^26.2.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
